# Base URL for the backend API (must end with /api).
# Local dev: leave unset to use the Vite proxy (/api -> http://localhost:5000).
# Production: point to the Render URL, e.g. https://your-api.onrender.com/api
VITE_API_URL=

# Only used by the Vite dev proxy when VITE_API_URL is unset.
VITE_PROXY_TARGET=http://localhost:5000
